{
  "name": "@memoir/tree",
  "version": "0.5.0",
  "description": "Ergonomic React family trees and org charts with relationship-aware layout.",
  "homepage": "https://github.com/memoirlabs/tree#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memoirlabs/tree.git"
  },
  "bugs": {
    "url": "https://github.com/memoirlabs/tree/issues"
  },
  "keywords": [
    "family-tree",
    "org-chart",
    "organization-chart",
    "react",
    "genealogy",
    "visualization"
  ],
  "license": "MIT",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && bun scripts/fix-dist-imports.ts",
    "check": "bun run lint && bun run typecheck && bun test && bun run build",
    "ci": "bun run ci:package && bun run ci:site",
    "ci:package": "bun run check",
    "ci:site": "bun run --cwd site ci",
    "deploy:package": "bun run npm:publish",
    "deploy:site": "bunx vercel deploy site --yes --no-wait",
    "deploy:site:prod": "bunx vercel deploy site --prod --yes --no-wait",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "portclean": "bash scripts/portclean.sh",
    "site": "bun run --cwd site dev",
    "site:check": "bun run --cwd site types:check && bun run --cwd site lint && bun run --cwd site build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "npm:audit": "bun scripts/audit-npm-package.ts",
    "npm:whoami": "bun scripts/npm-registry.ts whoami",
    "npm:pack": "bun scripts/npm-registry.ts pack",
    "npm:publish": "bun scripts/npm-registry.ts publish",
    "prepack": "bun run build",
    "prepublishOnly": "bun run check",
    "release": "bun scripts/release.ts",
    "release:dry-run": "bun scripts/release.ts --dry-run",
    "release:announcement": "bun scripts/generate-release-announcement.ts",
    "release:announcement:check": "bun run release:announcement && test -s RELEASE_ANNOUNCEMENT.md"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.67.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=19.0.0 <20.0.0"
  }
}
