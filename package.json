{
  "name": "@memoir/tree",
  "version": "0.1.2",
  "description": "Ergonomic React family tree component with relationship-aware layout.",
  "homepage": "https://github.com/memoirlabs/tree#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/memoirlabs/tree.git"
  },
  "bugs": {
    "url": "https://github.com/memoirlabs/tree/issues"
  },
  "keywords": [
    "family-tree",
    "react",
    "genealogy",
    "visualization"
  ],
  "license": "MIT",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "type": "module",
  "files": [
    "dist",
    "public/logo-transparent.png",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && bun scripts/fix-dist-imports.ts",
    "check": "bun run lint && bun run typecheck && bun test && bun run build",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "portclean": "bash scripts/portclean.sh",
    "site": "bun run --cwd site dev",
    "site:check": "bun run --cwd site types:check && bun run --cwd site lint && bun run --cwd site build",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run check",
    "release": "bun publish --access public"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.64.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=18.0.0 <20.0.0"
  }
}
