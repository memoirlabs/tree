{
  "name": "@memoir/tree",
  "version": "0.1.2",
  "description": "Family tree UI components with relationship-aware connectors.",
  "keywords": [
    "family-tree",
    "react",
    "graph",
    "visualization"
  ],
  "license": "MIT",
  "module": "dist/index.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && bun scripts/fix-dist-imports.ts",
    "check": "bun run lint && bun run typecheck && bun test && bun run build",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "playground": "bun --hot site/server.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "release": "npm version patch && npm publish --access public"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.64.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "^6.0.3"
  }
}
